# 复制为 .env.assets.local 后填写真实值。该本地文件已被 Git 忽略。
S3_ENDPOINT='https://s3.oss-cn-hangzhou.aliyuncs.com'
S3_REGION='cn-hangzhou'
S3_BUCKET='请填写私有 Bucket 名称'
S3_ACCESS_KEY_ID='请填写 AccessKey ID'
S3_ACCESS_KEY_SECRET='请填写 AccessKey Secret'
# 使用 STS 临时凭证时填写，否则保持为空。
S3_SESSION_TOKEN=''
S3_USE_PATH_STYLE='false'
S3_BUCKET_ENDPOINT='false'

S3_UPLOAD_URL_TTL='15m'
S3_DOWNLOAD_URL_TTL='5m'
ASSET_ALLOWED_MIME_TYPES='image/jpeg,image/png,image/webp,application/pdf,text/csv'
ASSET_MAX_SIZE_BYTES='104857600'
