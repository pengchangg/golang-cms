# 复制为 .env.assets.local 后填写真实值。该本地文件已被 Git 忽略。
ALIYUN_OSS_ENDPOINT='https://oss-cn-hangzhou.aliyuncs.com'
ALIYUN_OSS_REGION='cn-hangzhou'
ALIYUN_OSS_BUCKET='请填写私有 Bucket 名称'
ALIYUN_OSS_ACCESS_KEY_ID='请填写 AccessKey ID'
ALIYUN_OSS_ACCESS_KEY_SECRET='请填写 AccessKey Secret'
# 使用 STS 临时凭证时填写，否则保持为空。
ALIYUN_OSS_SECURITY_TOKEN=''

OSS_UPLOAD_URL_TTL='15m'
OSS_DOWNLOAD_URL_TTL='5m'
ASSET_ALLOWED_MIME_TYPES='image/jpeg,image/png,image/webp,application/pdf,text/csv'
ASSET_MAX_SIZE_BYTES='104857600'

APP_WORKER_OWNER='cms-local'
APP_WORKER_CONCURRENCY='2'
APP_WORKER_POLL_INTERVAL='1s'
APP_WORKER_LEASE_DURATION='60s'
APP_WORKER_RENEW_INTERVAL='20s'
