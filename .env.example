APP_LISTEN_ADDR=:8080
MYSQL_DSN=cms:cms@tcp(127.0.0.1:3306)/cms
# 仅本地或隔离测试网络可启用；远程 MySQL 应在 DSN 中配置可验证的 TLS。
MYSQL_ALLOW_INSECURE=false
WEB_DIST_DIR=web/dist
APP_BASE_URL=https://cms.example.com
APP_SESSION_SECRET=replace-with-at-least-32-random-bytes
APP_LOCAL_LOGIN_ENABLED=true
APP_ENV=production
SMS_PROVIDER=tencent
TENCENTCLOUD_SECRET_ID=replace-me
TENCENTCLOUD_SECRET_KEY=replace-me
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=1400000000
TENCENT_SMS_SIGN_NAME=replace-with-approved-sign
TENCENT_SMS_TEMPLATE_ID=000000
# 仅本地开发可改用 SMS_PROVIDER=fixed，并设置固定 6 位验证码。
DEV_SMS_FIXED_CODE=
# V1 默认启用并要求完整 S3 兼容对象存储配置；仅阶段二兼容部署可显式关闭。
APP_ASSETS_ENABLED=true
# 前端构建开关必须与 APP_ASSETS_ENABLED 一致；仅精确值 false 表示关闭。
VITE_ASSETS_ENABLED=true
S3_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com
S3_REGION=cn-hangzhou
S3_BUCKET=replace-with-private-bucket
S3_ACCESS_KEY_ID=replace-me
S3_ACCESS_KEY_SECRET=replace-me
# 使用 STS 时提供，禁止写入日志。
S3_SESSION_TOKEN=
S3_USE_PATH_STYLE=false
# Endpoint 已绑定单个 Bucket 的 CNAME 场景设为 true；不能与 path style 同时启用。
S3_BUCKET_ENDPOINT=false
S3_UPLOAD_URL_TTL=15m
S3_DOWNLOAD_URL_TTL=5m
ASSET_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/csv
ASSET_MAX_SIZE_BYTES=104857600
