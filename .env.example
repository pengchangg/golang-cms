APP_LISTEN_ADDR=:8080
MYSQL_DSN=cms:cms@tcp(127.0.0.1:3306)/cms
# 仅本地或隔离测试网络可启用；远程 MySQL 应在 DSN 中配置可验证的 TLS。
MYSQL_ALLOW_INSECURE=false
WEB_DIST_DIR=web/dist
APP_BASE_URL=https://cms.example.com
APP_SESSION_SECRET=replace-with-at-least-32-random-bytes
APP_LOCAL_LOGIN_ENABLED=true
APP_OIDC_ENABLED=true
OIDC_ISSUER_URL=https://sso.example.com/realms/internal
OIDC_CLIENT_ID=internal-cms
OIDC_CLIENT_SECRET=replace-me
OIDC_REDIRECT_URL=https://cms.example.com/api/admin/v1/auth/oidc/callback
# V1 默认启用并要求完整 OSS 配置；仅阶段二兼容部署可显式关闭。
APP_ASSETS_ENABLED=true
# 前端构建开关必须与 APP_ASSETS_ENABLED 一致；仅精确值 false 表示关闭。
VITE_ASSETS_ENABLED=true
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_REGION=cn-hangzhou
ALIYUN_OSS_BUCKET=replace-with-private-bucket
ALIYUN_OSS_ACCESS_KEY_ID=replace-me
ALIYUN_OSS_ACCESS_KEY_SECRET=replace-me
# 使用 STS 时提供，禁止写入日志。
ALIYUN_OSS_SECURITY_TOKEN=
OSS_UPLOAD_URL_TTL=15m
OSS_DOWNLOAD_URL_TTL=5m
ASSET_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/csv
ASSET_MAX_SIZE_BYTES=104857600
APP_WORKER_OWNER=cms-1
APP_WORKER_CONCURRENCY=2
APP_WORKER_POLL_INTERVAL=1s
APP_WORKER_LEASE_DURATION=60s
APP_WORKER_RENEW_INTERVAL=20s
