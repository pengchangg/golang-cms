APP_LISTEN_ADDR=:8080
MYSQL_DSN=cms:cms@tcp(127.0.0.1:3306)/cms
# 仅本地或隔离测试网络可启用；远程 MySQL 应在 DSN 中配置可验证的 TLS。
MYSQL_ALLOW_INSECURE=false
WEB_DIST_DIR=web/dist
APP_BASE_URL=https://cms.example.com
APP_SESSION_SECRET=replace-with-at-least-32-random-bytes
APP_LOCAL_LOGIN_ENABLED=true
APP_OIDC_ENABLED=true
OIDC_ISSUER_URL=https://sso.example.com/realms/internal
OIDC_CLIENT_ID=internal-cms
OIDC_CLIENT_SECRET=replace-me
OIDC_REDIRECT_URL=https://cms.example.com/api/admin/v1/auth/oidc/callback
